---
import MainLayout from '../layouts/MainLayout.astro';
import { siteData } from '../data/site.js';

const pageTitle = `${siteData.identity.name} | Personal site`;

const devopsSkills = ['Linux', 'Docker', 'Kubernetes', 'Terraform', 'Jenkins', 'Ansible', 'Git', 'GitHub', 'Bash', 'CI/CD'];
const cloudSkills = ['AWS', 'Azure', 'GCP', 'IaaS', 'PaaS', 'SaaS', 'Serverless', 'Security', 'Management', 'Multi-Cloud', 'Cloud Migration'];
const programmingSkills = ['Python', 'Java', 'C++', 'C#', 'OOP', 'Agile', 'TDD', 'Ajax', 'PHP'];
const devSkills = ['HTML', 'CSS', 'SASS', 'Bootstrap', 'JavaScript', 'jQuery', 'React', 'Angular', 'Express.js', 'Node.js', '.Net', 'Kotlin', 'Flask', 'Django'];
const dbSkills = ['SQL', 'MySQL', 'PostgreSQL', 'MongoDB', 'Schema', 'Normalization', 'Joins'];
const marketingSkills = ['SEO', 'Content Writing', 'Keyword Research', 'WordPress'];
const designSkills = ['Figma', 'Adobe XD', 'Adobe Photoshop', 'UI/UX Design'];
---

<MainLayout title={pageTitle}>

  <!-- ===== Home Section ===== -->
  <section class="home panel-section" id="home" data-panel>
    <div class="home-container">
      <div class="home-info padd-15">
        <h3 class="hello">Hi, I'm <span class="name">Hassaan</span></h3>
        <h3 class="my-profession">A Freelance <span class="typing"></span> Engineer</h3>
        <p>I'm a Top-Rated Freelancer with an extensive experience for over 5 years</p>
        <a href={siteData.links.tools} class="btn">Use Awesome Web Utility Tools for Free</a>
      </div>

      <div class="home-img padd-15">
        <img src="/images/portrait.jpg" alt="Hassaan" loading="eager" />
      </div>
    </div>
  </section>

  <!-- ===== About Section ===== -->
  <section class="section-block panel-section" id="about" data-panel>
    <div class="section-title"><h2>About Me</h2></div>

    <div class="about-row">
      <!-- Left: bio text -->
      <div class="about-text">
        <h3>My name is <span>{siteData.identity.name}</span> and I am a <span>Freelancer</span></h3>
        <p>{siteData.identity.summary} {siteData.identity.intro}</p>
      </div>
    </div>

    <div class="about-row">
      <!-- Personal info -->
      <div class="personal-info">
        <div class="info-item"><p>Email: <span><a href={siteData.links.email}>{siteData.identity.email}</a></span></p></div>
        <div class="info-item"><p>Website: <span><a href={siteData.links.site} target="_blank">muhammadhassaanjaved.com</a></span></p></div>
        <div class="info-item"><p>Portfolio: <span><a href={siteData.links.portfolio} target="_blank">portfolio.muhammadhassaanjaved.com</a></span></p></div>
        <div class="info-item"><p>Phone: <span><a href={siteData.links.phone}>{siteData.identity.phone}</a></span></p></div>
        <div class="info-item"><p>Location: <span>{siteData.identity.location}</span></p></div>
        <div class="buttons" style="margin-top: 2rem;">
          <a href="#contact" data-rail-link class="btn">Contact Now</a>
        </div>
      </div>

      <!-- Language skills -->
      <div class="lang-skills">
        {[['Urdu', '100%'], ['English', '90%']].map(([lang, pct]) => (
          <div class="skill-item">
            <h5>{lang}</h5>
            <div class="progress shadow-dark">
              <div class="progress-in" style={`width: ${pct};`}></div>
              <div class="skill-percent">{pct}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Interests / Passions / Hobbies / Goals — 2x2 grid -->
    <div class="timeline-row" style="margin-top: 30px;">
      <div class="timeline-col-half">
        <h3 class="subsection-title">Interests</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {['DevOps Engineering', 'Cloud Computing', 'Artificial Intelligence', 'Business Development', 'Digital Marketing'].map(item => (
              <div class="timeline-item"><div class="circle-dot"></div><h4 class="timeline-title">{item}</h4></div>
            ))}
          </div>
        </div>
      </div>

      <div class="timeline-col-half">
        <h3 class="subsection-title">Passions</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {['Lifelong Learning', 'Technological Mystery', 'Continuous Innovation', 'Continuous Automation', 'Building Efficient Systems'].map(item => (
              <div class="timeline-item"><div class="circle-dot"></div><h4 class="timeline-title">{item}</h4></div>
            ))}
          </div>
        </div>
      </div>

      <div class="timeline-col-half">
        <h3 class="subsection-title">Hobbies</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {['Travel', 'Sports', 'Movies', 'Music', 'Games'].map(item => (
              <div class="timeline-item"><div class="circle-dot"></div><h4 class="timeline-title">{item}</h4></div>
            ))}
          </div>
        </div>
      </div>

      <div class="timeline-col-half">
        <h3 class="subsection-title">Goals</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {['Learn Personal and Soft Skills', 'Achieve Work-Life Balance', 'Mentor Aspiring Technologists', 'Contribute to Open-Source', 'Volunteer for non-profit Organizations'].map(item => (
              <div class="timeline-item"><div class="circle-dot"></div><h4 class="timeline-title">{item}</h4></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Qualifications Section ===== -->
  <section class="section-block panel-section" id="qualifications" data-panel>
    <div class="section-title"><h2>Qualifications</h2></div>

    <div class="qual-grid">
      <!-- LEFT COLUMN: Education, Certificates, Workshops -->
      <div class="padd-15">
        <h3 class="subsection-title">Education</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {siteData.education.map((item) => (
              <div class="timeline-item">
                <div class="circle-dot"></div>
                <h3 class="timeline-date"><i class="fa fa-calendar"></i> {item.range}</h3>
                <h4 class="timeline-title">{item.title}</h4>
                <p class="timeline-text">{item.org}</p>
              </div>
            ))}
          </div>
        </div>

        <h3 class="subsection-title" style="margin-top: 2rem;">Certificates</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {siteData.certificates.map((item) => (
              <div class="timeline-item">
                <div class="circle-dot"></div>
                <h3 class="timeline-date"><i class="fa fa-calendar"></i> {item.range}</h3>
                <h4 class="timeline-title">{item.title}</h4>
                <p class="timeline-text">{item.org}</p>
              </div>
            ))}
          </div>
        </div>

        <h3 class="subsection-title" style="margin-top: 2rem;">Workshops</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {siteData.workshops.map((item) => (
              <div class="timeline-item">
                <div class="circle-dot"></div>
                <h3 class="timeline-date"><i class="fa fa-calendar"></i> {item.range}</h3>
                <h4 class="timeline-title">{item.title}</h4>
                <p class="timeline-text">{item.org}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN: Experience, Licences, Courses -->
      <div class="padd-15">
        <h3 class="subsection-title">Experience</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {siteData.experience.map((item) => (
              <div class="timeline-item">
                <div class="circle-dot"></div>
                <h3 class="timeline-date"><i class="fa fa-calendar"></i> {item.range}</h3>
                <h4 class="timeline-title">{item.title}</h4>
                <p class="timeline-text">{item.org}</p>
              </div>
            ))}
          </div>
        </div>

        <h3 class="subsection-title" style="margin-top: 2rem;">Licences</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {siteData.credentials.map((item) => (
              <div class="timeline-item">
                <div class="circle-dot"></div>
                <h3 class="timeline-date"><i class="fa fa-calendar"></i> {item.range}</h3>
                <h4 class="timeline-title">{item.title}</h4>
                <p class="timeline-text">{item.org}</p>
              </div>
            ))}
          </div>
        </div>

        <h3 class="subsection-title" style="margin-top: 2rem;">Courses</h3>
        <div class="timeline-box">
          <div class="timeline shadow-dark">
            {siteData.courses.map((item) => (
              <div class="timeline-item">
                <div class="circle-dot"></div>
                <h3 class="timeline-date"><i class="fa fa-calendar"></i> {item.range}</h3>
                <h4 class="timeline-title">{item.title}</h4>
                <p class="timeline-text">{item.org}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Skills Section ===== -->
  <section class="section-block panel-section" id="skills" data-panel>
    <div class="section-title"><h2>Skills</h2></div>

    <div class="skills-category">
      <h3 class="skills-heading">DevOps</h3>
      <div class="skills-grid">
        {devopsSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>

    <div class="skills-category">
      <h3 class="skills-heading">Cloud</h3>
      <div class="skills-grid">
        {cloudSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>

    <div class="skills-category">
      <h3 class="skills-heading">Programming</h3>
      <div class="skills-grid">
        {programmingSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>

    <div class="skills-category">
      <h3 class="skills-heading">Development</h3>
      <div class="skills-grid">
        {devSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>

    <div class="skills-category">
      <h3 class="skills-heading">Database</h3>
      <div class="skills-grid">
        {dbSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>

    <div class="skills-category">
      <h3 class="skills-heading">Marketing</h3>
      <div class="skills-grid">
        {marketingSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>

    <div class="skills-category">
      <h3 class="skills-heading">Designing</h3>
      <div class="skills-grid">
        {designSkills.map(s => <div class="skill-tile"><h3>{s}</h3></div>)}
      </div>
    </div>
  </section>

  <!-- ===== Projects Section ===== -->
  <section class="section-block panel-section" id="projects" data-panel>
    <div class="section-title"><h2>Projects</h2></div>

    <div class="portfolio-grid">
      {siteData.selectedProjects.map((project) => (
        <div class="portfolio-item">
          <a href={project.href} target="_blank" rel="noreferrer">
            <div class="portfolio-item-inner">
              <div class="portfolio-img">
                <img src={project.image} alt={project.title} loading="lazy" />
              </div>
              <div class="portfolio-text">
                <p class="portfolio-label">{project.note}</p>
                <h3 class="portfolio-title">{project.title}</h3>
                <p class="portfolio-desc">{project.summary}</p>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== Services Section ===== -->
  <section class="section-block panel-section" id="services" data-panel>
    <div class="section-title"><h2>Services</h2></div>

    <div class="services-grid">
      {siteData.capabilityGroups.map((group, i) => {
        const icons = ['fa-cloud', 'fa-cogs', 'fa-robot', 'fa-code'];
        return (
          <div class="service-item">
            <div class="service-item-inner">
              <div class="icon"><i class={`fa ${icons[i] || 'fa-cogs'}`}></i></div>
              <h4>{group.title}</h4>
              <p>{group.summary}</p>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ===== Publications Section ===== -->
  <section class="section-block panel-section" id="publications" data-panel>
    <div class="section-title"><h2>Publications</h2></div>

    <div class="portfolio-grid">
      {siteData.publications.map((pub) => (
        <div class="portfolio-item">
          <a href={pub.href} target="_blank" rel="noreferrer">
            <div class="portfolio-item-inner">
              <div class="portfolio-img">
                <img src={pub.image} alt={pub.title} loading="lazy" />
              </div>
              <div class="portfolio-text">
                <p class="portfolio-label">{pub.note}</p>
                <h3 class="portfolio-title">{pub.title}</h3>
                <p class="portfolio-desc">{pub.summary}</p>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== References Section ===== -->
  <section class="section-block panel-section" id="references" data-panel>
    <div class="section-title"><h2>References</h2></div>

    <div class="services-grid">
      <div class="service-item">
        <div class="service-item-inner">
          <div class="icon"><i class="fa fa-phone"></i></div>
          <h4>Ahmer Khan</h4>
          <p>+92 321 4499487</p>
        </div>
      </div>
      <div class="service-item">
        <div class="service-item-inner">
          <div class="icon"><i class="fa fa-phone"></i></div>
          <h4>Asfandyar Akbar</h4>
          <p>+92 336 9866642</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Contact Section ===== -->
  <section class="section-block panel-section" id="contact" data-panel>
    <div class="section-title"><h2>Contact</h2></div>

    <h3 class="contact-title">Do You Have Any Questions?</h3>
    <h4 class="contact-sub-title">I'M AT YOUR SERVICE</h4>

    <div class="contact-info-grid">
      <a href={siteData.links.phone} target="_blank" class="contact-info-link">
        <div class="contact-info-item-inner">
          <div class="icon"><i class="fas fa-phone"></i></div>
          <h4>Call</h4>
        </div>
      </a>
      <a href={siteData.links.maps} target="_blank" class="contact-info-link">
        <div class="contact-info-item-inner">
          <div class="icon"><i class="fas fa-location-dot"></i></div>
          <h4>Location</h4>
        </div>
      </a>
      <a href={siteData.links.email} target="_blank" class="contact-info-link">
        <div class="contact-info-item-inner">
          <div class="icon"><i class="fas fa-envelope"></i></div>
          <h4>Email</h4>
        </div>
      </a>
      <a href={siteData.links.site} target="_blank" class="contact-info-link">
        <div class="contact-info-item-inner">
          <div class="icon"><i class="fas fa-globe"></i></div>
          <h4>Website</h4>
        </div>
      </a>
    </div>

    <h3 class="contact-title" style="margin-top: 3rem;">SEND ME AN EMAIL</h3>
    <h4 class="contact-sub-title">I'M VERY RESPONSIVE TO MESSAGES</h4>

    <div class="contact-form-wrap" id="form-container">
      <form id="contact-form">
        <div class="form-row">
          <div class="form-item col-6">
            <input type="text" name="name" placeholder="Name" class="form-control" required />
          </div>
          <div class="form-item col-6">
            <input type="email" name="email" placeholder="Email" class="form-control" required />
          </div>
        </div>
        <div class="form-item">
          <input type="text" name="subject" placeholder="Subject" class="form-control" />
        </div>
        <div class="form-item">
          <textarea name="message" placeholder="Message" rows="6" class="form-control"></textarea>
        </div>
        <div class="form-item">
          <button type="submit" class="btn">Send Message</button>
        </div>
      </form>

      <!-- Lottie feedback overlay — shown during/after submission -->
      <div id="feedback-overlay">
        <canvas id="feedback-canvas"></canvas>
      </div>
    </div>
  </section>

</MainLayout>
