---
import 'crusher-ui-kit/runtime';
import 'crusher-ui-kit/styles/tokens.css';
import 'crusher-ui-kit/styles/modes.css';
import 'crusher-ui-kit/styles/semantic.css';
import 'crusher-ui-kit/styles/bridge.css';
import 'crusher-ui-kit/themes/minimal.css';
import '../styles/site.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="minimal" data-mode="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Muhammad Hassaan Javed — Senior DevOps & Cloud Engineer" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Google Fonts — Poppins + Clicker Script (matching old site) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Clicker+Script&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Font Awesome (matching old site icon set) -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

		<!-- Typed.js — for home section typing animation -->
		<script src="https://cdnjs.cloudflare.com/ajax/libs/typed.js/2.1.0/typed.umd.js" is:inline></script>

		<!-- EmailJS — contact form submissions -->
		<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js" is:inline></script>
	</head>
	<body>
		<!-- Custom colour & mode switcher — matches old site exactly -->
		<div class="style-switcher" id="style-switcher">
			<div class="style-switcher-toggler s-icon" id="switcher-toggle">
				<i class="fas fa-cog fa-spin"></i>
			</div>
			<div class="day-night s-icon" id="switcher-daynight">
				<i class="fas fa-moon"></i>
			</div>
			<h4>Theme Colors</h4>
			<div class="colors">
				<span class="color-1" data-color="#37b182" title="color-1"></span>
				<span class="color-2" data-color="#1854b4" title="color-2"></span>
				<span class="color-3" data-color="#fa5b0f" title="color-3"></span>
				<span class="color-4" data-color="#f021b2" title="color-4"></span>
				<span class="color-5" data-color="#ec1839" title="color-5"></span>
			</div>
		</div>
		<crusher-toast-center></crusher-toast-center>

		<div class="site-shell">
			<!-- Sidebar rail — mirrors old .aside -->
			<aside class="site-rail" data-site-rail>
				<div class="rail-inner">
					<!-- Brand — matches old "Crusher" logo with corner brackets -->
					<div class="logo">
						<a href="#home" data-rail-link><span>C</span>rusher</a>
					</div>

					<!-- Mobile toggler button -->
					<button class="rail-toggle" type="button" data-rail-toggle aria-label="Open navigation">
						<span class="rail-toggle-icon" aria-hidden="true"></span>
					</button>

					<!-- Navigation — same links as old site -->
					<nav class="rail-nav" aria-label="Primary">
						<a data-rail-link href="#home"><i class="fa fa-home"></i> Home</a>
						<a data-rail-link href="#about"><i class="fa fa-user"></i> About</a>
						<a data-rail-link href="#qualifications"><i class="fa fa-mortar-board"></i> Qualifications</a>
						<a data-rail-link href="#skills"><i class="fa fa-star"></i> Skills</a>
						<a data-rail-link href="#projects"><i class="fa fa-briefcase"></i> Projects</a>
						<a data-rail-link href="#services"><i class="fa fa-tags"></i> Services</a>
						<a data-rail-link href="#publications"><i class="fa fa-book"></i> Publications</a>
						<a data-rail-link href="#references"><i class="fa fa-address-card"></i> References</a>
						<a data-rail-link href="#contact"><i class="fa fa-comments"></i> Contact</a>
					</nav>

					<!-- Footer copyright -->
					<div class="rail-footer">
						<p class="rail-copyright">Copyright &copy; Created by <a href="https://www.linkedin.com/in/itxcrusher" target="_blank" style="color: var(--skin-color); text-decoration: none;">Hassaan</a></p>
					</div>
				</div>
			</aside>

			<!-- Mobile overlay (tap to close nav) -->
			<button class="rail-overlay" type="button" data-rail-overlay aria-label="Close navigation"></button>

			<!-- Main content area — panels stack here -->
			<main class="site-main" id="top">
				<slot />
			</main>
		</div>

		<script>
			import '../scripts/site.js';

			document.addEventListener('DOMContentLoaded', () => {

				// ---- Typed.js animation ----
				if (typeof Typed !== 'undefined' && document.querySelector('.typing')) {
					new Typed('.typing', {
						strings: ['', 'DevOps', 'Cloud', 'AI'],
						typeSpeed: 150,
						backSpeed: 10,
						loop: true,
					});
				}

				// ---- Custom colour & mode switcher ----
				const switcher = document.getElementById('style-switcher');
				const toggle = document.getElementById('switcher-toggle');
				const dayNight = document.getElementById('switcher-daynight');

				toggle && toggle.addEventListener('click', () => {
					switcher.classList.toggle('open');
				});

				window.addEventListener('scroll', () => {
					switcher && switcher.classList.remove('open');
				});

				// Colour swatches
				document.querySelectorAll('.style-switcher .colors span').forEach(swatch => {
					swatch.addEventListener('click', () => {
						const color = swatch.getAttribute('data-color');
						document.documentElement.style.setProperty('--skin-color', color);
						localStorage.setItem('skin-color', color);
					});
				});

				// Dark / light toggle
				function applyTheme(dark) {
					document.documentElement.classList.toggle('dark', dark);
					const icon = dayNight && dayNight.querySelector('i');
					if (icon) {
						icon.classList.toggle('fa-sun', dark);
						icon.classList.toggle('fa-moon', !dark);
					}
				}

				dayNight && dayNight.addEventListener('click', () => {
					const isDark = document.documentElement.classList.contains('dark');
					applyTheme(!isDark);
					localStorage.setItem('theme', !isDark ? 'dark' : 'light');
				});

				// Restore saved prefs
				const savedColor = localStorage.getItem('skin-color');
				if (savedColor) document.documentElement.style.setProperty('--skin-color', savedColor);
				const savedTheme = localStorage.getItem('theme');
				if (savedTheme) applyTheme(savedTheme === 'dark');

				// ---- Contact form — EmailJS ----
				if (typeof emailjs !== 'undefined') {
					emailjs.init({ publicKey: 'XZB7nrR299U0EOFrp' });
				}

				const contactForm = document.getElementById('contact-form');
				const formContainer = document.getElementById('form-container');
				const feedbackOverlay = document.getElementById('feedback-overlay');
				const feedbackCanvas = document.getElementById('feedback-canvas');

				function loadLottie(src) {
					import('https://cdn.jsdelivr.net/npm/@lottiefiles/dotlottie-web/+esm').then(({ DotLottie }) => {
						new DotLottie({
							autoplay: true,
							loop: false,
							canvas: feedbackCanvas,
							src,
						});
					}).catch(() => {});
				}

				function showFeedback(src, durationMs = 5000) {
					feedbackOverlay.style.display = 'flex';
					formContainer.classList.add('processing');
					loadLottie(src);
					setTimeout(() => {
						feedbackOverlay.style.display = 'none';
						formContainer.classList.remove('processing');
					}, durationMs);
				}

				contactForm && contactForm.addEventListener('submit', function (e) {
					e.preventDefault();

					if (typeof emailjs === 'undefined') {
						showFeedback('https://lottie.host/68dbbd9d-3009-4719-8b44-748855ba9535/aX6YS86frQ.lottie');
						return;
					}

					formContainer.classList.add('processing');

					emailjs.sendForm('service_fmz6mxd', 'template_3brgp3p', contactForm)
						.then(() => {
							contactForm.reset();
							showFeedback('https://lottie.host/4cb8169d-7231-4f2f-b93f-bb7e74c4d508/fVrcT66ihx.lottie', 7000);
						})
						.catch(() => {
							// Use direct lottie file URL (not /embed/ — that causes CORS)
							showFeedback('https://lottie.host/68dbbd9d-3009-4719-8b44-748855ba9535/aX6YS86frQ.lottie', 5000);
						});
				});
			});
		</script>
	</body>
</html>
