---
import 'crusher-ui-kit/runtime';
import 'crusher-ui-kit/styles/tokens.css';
import 'crusher-ui-kit/styles/modes.css';
import 'crusher-ui-kit/styles/semantic.css';
import 'crusher-ui-kit/styles/bridge.css';
import 'crusher-ui-kit/themes/minimal.css';
import '../styles/site.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="minimal" data-mode="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Muhammad Hassaan Javed — Senior DevOps & Cloud Engineer" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Google Fonts — Poppins + Clicker Script (matching old site) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Clicker+Script&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Font Awesome (matching old site icon set) -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
	</head>
	<body>
		<!-- Style switcher + toast (keep from framework) -->
		<crusher-style-switcher></crusher-style-switcher>
		<crusher-toast-center></crusher-toast-center>

		<div class="site-shell">
			<!-- Sidebar rail — mirrors old .aside -->
			<aside class="site-rail" data-site-rail>
				<div class="rail-inner">
					<!-- Brand — matches old "Crusher" logo with corner brackets -->
					<div class="logo">
						<a href="#home" data-rail-link><span>C</span>rusher</a>
					</div>

					<!-- Mobile toggler button -->
					<button class="rail-toggle" type="button" data-rail-toggle aria-label="Open navigation">
						<span class="rail-toggle-icon" aria-hidden="true"></span>
					</button>

					<!-- Navigation — same links as old site -->
					<nav class="rail-nav" aria-label="Primary">
						<a data-rail-link href="#home"><i class="fa fa-home"></i> Home</a>
						<a data-rail-link href="#about"><i class="fa fa-user"></i> About</a>
						<a data-rail-link href="#qualifications"><i class="fa fa-mortar-board"></i> Qualifications</a>
						<a data-rail-link href="#skills"><i class="fa fa-star"></i> Skills</a>
						<a data-rail-link href="#projects"><i class="fa fa-briefcase"></i> Projects</a>
						<a data-rail-link href="#services"><i class="fa fa-tags"></i> Services</a>
						<a data-rail-link href="#publications"><i class="fa fa-book"></i> Publications</a>
						<a data-rail-link href="#references"><i class="fa fa-address-card"></i> References</a>
						<a data-rail-link href="#contact"><i class="fa fa-comments"></i> Contact</a>
					</nav>

					<!-- Footer copyright -->
					<div class="rail-footer">
						<p class="rail-copyright">Copyright &copy; Created by <a href="https://www.linkedin.com/in/itxcrusher" target="_blank" style="color: var(--skin-color); text-decoration: none;">Hassaan</a></p>
					</div>
				</div>
			</aside>

			<!-- Mobile overlay (tap to close nav) -->
			<button class="rail-overlay" type="button" data-rail-overlay aria-label="Close navigation"></button>

			<!-- Main content area — panels stack here -->
			<main class="site-main" id="top">
				<slot />
			</main>
		</div>

		<script>
			import '../scripts/site.js';

			// Back-section animation on panel switch (matches old site slide effect)
			document.addEventListener('DOMContentLoaded', () => {
				const panels = document.querySelectorAll('.panel-section');
				const links = document.querySelectorAll('[data-rail-link]');

				links.forEach(link => {
					link.addEventListener('click', () => {
						const currentActive = document.querySelector('.panel-section.is-active');
						if (currentActive) {
							panels.forEach(p => p.classList.remove('back-section'));
							currentActive.classList.add('back-section');
							setTimeout(() => {
								currentActive.classList.remove('back-section');
							}, 600);
						}
					});
				});
			});
		</script>
	</body>
</html>
